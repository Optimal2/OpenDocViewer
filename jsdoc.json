{
  "tags": {
    "allowUnknownTags": true
  },
  "source": {
    "include": [
      "src",
      "server"
    ],
    "includePattern": "\\.(js|jsx)$",
    "excludePattern": "(node_modules/|docs/|__tests__/|\\.test\\.)"
  },
  "plugins": [
    "plugins/markdown"
  ],
  "templates": {
    "cleverLinks": true,
    "monospaceLinks": true
  },
  "opts": {
    "encoding": "utf8",
    "destination": "./docs/",
    "recurse": true,
    "readme": "README.md",
    "template": "node_modules/docdash"
  }
}
