{
  "name": "opendocviewer",
  "version": "2.6.3",
  "private": true,
  "description": "Fast, lightweight document viewer (PDF, TIFF, images) built with React + Vite, with a token-gated log server and runtime configuration.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Optimal2/OpenDocViewer.git"
  },
  "homepage": "https://github.com/Optimal2/OpenDocViewer#readme",
  "bugs": {
    "url": "https://github.com/Optimal2/OpenDocViewer/issues"
  },
  "keywords": [
    "pdf",
    "tiff",
    "viewer",
    "react",
    "vite",
    "document",
    "opendocviewer"
  ],
  "engines": {
    "node": "^22.18.0 || >=24.11.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{js,jsx}\"",
    "lint:fix": "eslint \"src/**/*.{js,jsx}\" --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css,scss,md}\"",
    "doc": "jsdoc -c jsdoc.json",
    "doc:agent": "node scripts/generate-agent-docs.mjs",
    "start:system-log": "node server/system-log-server.js",
    "start:user-log": "node server/user-log-server.js",
    "start:logs": "concurrently -n sys,user -c auto \"npm run start:system-log\" \"npm run start:user-log\"",
    "dev:system-log": "cross-env NODE_ENV=development PORT=3001 LOG_TOKEN=devtoken node server/system-log-server.js",
    "dev:user-log": "cross-env NODE_ENV=development PORT=3002 node server/user-log-server.js",
    "dev:logs": "concurrently -n sys,user -c auto \"npm run dev:system-log\" \"npm run dev:user-log\"",
    "dev:both": "concurrently -n app,logs -c auto \"npm run dev\" \"npm run dev:logs\"",
    "// release helpers": "Run one of the release:* scripts, then push with --follow-tags.",
    "release:patch": "npm version patch -m \"chore(release): %s\"",
    "release:minor": "npm version minor -m \"chore(release): %s\"",
    "release:major": "npm version major -m \"chore(release): %s\""
  },
  "dependencies": {
    "axios": "^1.18.0",
    "cors": "^2.8.6",
    "dompurify": "^3.4.10",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "file-type": "^22.0.1",
    "helmet": "^8.2.0",
    "i18next": "^26.3.1",
    "i18next-http-backend": "^4.0.0",
    "i18next-icu": "^2.4.3",
    "jspdf": "^4.2.1",
    "material-icons": "^1.13.14",
    "morgan": "^1.11.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "prop-types": "^15.8.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "utif2": "^4.1.0"
  },
  "devDependencies": {
    "@babel/core": "^8.0.0",
    "@babel/plugin-transform-runtime": "^8.0.0",
    "@babel/runtime": "^8.0.0",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "docdash": "^2.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "jsdoc": "^4.0.5",
    "prettier": "^3.8.4",
    "rolldown": "^1.1.1",
    "vite": "^8.0.16"
  },
  "overrides": {
    "flatted": "^3.4.2",
    "lodash": "^4.18.0",
    "path-to-regexp": "^8.4.0",
    "picomatch": "^4.0.4"
  }
}
