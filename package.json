{
  "name": "opendocviewer",
  "version": "1.9.1",
  "private": true,
  "description": "Fast, lightweight document viewer (PDF, TIFF, images) built with React + Vite, with a token-gated log server and runtime configuration.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Optimal2/OpenDocViewer.git"
  },
  "homepage": "https://github.com/Optimal2/OpenDocViewer#readme",
  "bugs": {
    "url": "https://github.com/Optimal2/OpenDocViewer/issues"
  },
  "keywords": [
    "pdf",
    "tiff",
    "viewer",
    "react",
    "vite",
    "document",
    "opendocviewer"
  ],
  "engines": {
    "node": ">=20.19.0 <21 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{js,jsx}\"",
    "lint:fix": "eslint \"src/**/*.{js,jsx}\" --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css,scss,md}\"",
    "doc": "jsdoc -c jsdoc.json",
    "start:system-log": "node server/system-log-server.js",
    "start:user-log": "node server/user-log-server.js",
    "start:logs": "concurrently -n sys,user -c auto \"npm run start:system-log\" \"npm run start:user-log\"",
    "dev:system-log": "cross-env NODE_ENV=development PORT=3001 LOG_TOKEN=devtoken node server/system-log-server.js",
    "dev:user-log": "cross-env NODE_ENV=development PORT=3002 node server/user-log-server.js",
    "dev:logs": "concurrently -n sys,user -c auto \"npm run dev:system-log\" \"npm run dev:user-log\"",
    "dev:both": "concurrently -n app,logs -c auto \"npm run dev\" \"npm run dev:logs\"",
    "// release helpers": "Run one of the release:* scripts, then push with --follow-tags.",
    "release:patch": "npm version patch -m \"chore(release): %s\"",
    "release:minor": "npm version minor -m \"chore(release): %s\"",
    "release:major": "npm version major -m \"chore(release): %s\""
  },
  "dependencies": {
    "@formatjs/icu-messageformat-parser": "^3.5.7",
    "axios": "^1.16.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dompurify": "^3.4.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "file-type": "^22.0.1",
    "helmet": "^8.1.0",
    "i18next": "^26.0.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^4.0.0",
    "i18next-icu": "^2.4.3",
    "jspdf": "^4.2.1",
    "morgan": "^1.10.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.7.284",
    "prop-types": "^15.8.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.7",
    "react-window": "^2.2.7",
    "utif2": "^4.1.0",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@babel/plugin-transform-private-property-in-object": "^7.28.6",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@typescript-eslint/utils": "^8.59.2",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "docdash": "^2.0.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdoc": "^4.0.5",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "vite": "^8.0.11",
    "vite-plugin-svgr": "^5.2.0"
  },
  "overrides": {
    "flatted": "^3.4.2",
    "lodash": "^4.18.0",
    "path-to-regexp": "^8.4.0",
    "picomatch": "^4.0.4"
  }
}
